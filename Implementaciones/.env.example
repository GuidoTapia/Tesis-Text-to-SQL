# Copiar a `.env` (ignorado por git) y completar con credenciales reales.
# Nunca commitear el `.env` con valores. Nunca compartir keys en chats o issues.

# Anthropic — proveedor de LLM inicial del proyecto (ver DECISIONS.md)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo por defecto para fase exploratoria (Haiku 4.5).
# Alternativas: claude-sonnet-4-6, claude-opus-4-7.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
